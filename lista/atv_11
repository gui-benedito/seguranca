#!/usr/bin/env bash

#!/bin/bash

echo "RELATÓRIO DE PACOTES INSTALADOS NA ÚLTIMA SEMANA"
echo "Data do relatório: $(date +'%d/%m/%Y')"
echo "----------------------------------------"

for arquivo in /var/log/dpkg.log /var/log/dpkg.log.1
do
    [ -f "$arquivo" ] || continue

    grep " install " "$arquivo" | while read -r linha
    do
        data_log=$(echo "$linha" | awk '{print $1}')
        hora_log=$(echo "$linha" | awk '{print $2}')
        pacote=$(echo "$linha" | awk '{print $4}')

        data_segundos=$(date -d "$data_log" +%s 2>/dev/null)
        limite_segundos=$(date -d "7 days ago" +%s)

        if [ "$data_segundos" -ge "$limite_segundos" ]; then
            echo "Data: $(date -d "$data_log" +'%d/%m/%Y') | Hora: $hora_log | Pacote: $pacote"
        fi
    done
done
